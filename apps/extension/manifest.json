{
  "manifest_version": 3,
  "name": "Job Finder Agent - Sync Helper",
  "version": "1.1.0",
  "description": "Sync LinkedIn job postings and recruiter messages straight to your Job Finder Agent Kanban Board.",
  "permissions": ["storage", "activeTab", "scripting", "cookies"],
  "host_permissions": ["https://www.linkedin.com/*", "http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "http://localhost:3000/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
